{
  "name": "@averi/mcp",
  "version": "0.0.1",
  "description": "MCP server for verifying mobile app changes on iOS Simulators and Android Emulators",
  "type": "module",
  "bin": {
    "averi-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist",
    "skill",
    "ARCHITECTURE.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "mobile",
    "testing",
    "ios-simulator",
    "android-emulator",
    "agent",
    "verification"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepublishOnly": "npm test && npm run build",
    "build": "rm -rf dist && tsc",
    "dev": "tsx src/mcp/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "fast-xml-parser": "^5.9.3",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  },
  "author": "Michal Holécy <michal.holecy@finshape.com>"
}
